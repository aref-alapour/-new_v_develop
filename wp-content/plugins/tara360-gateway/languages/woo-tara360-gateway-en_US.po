msgid "درگاه پرداخت تارا برای ووکامرس."
msgstr "Tara Payment Gateway for WooCommerce."

msgid "فعال/غیرفعال"
msgstr "Enable/Disable"

msgid "فعال سازی درگاه پرداخت تارا"
msgstr "Enable Tara Payment Gateway"

msgid "عنوان"
msgstr "Title"

msgid "توضیحات"
msgstr "Description"

msgid "نام کاربری تارا"
msgstr "Tara Username"

msgid "رمز عبور تارا"
msgstr "Tara Password"

msgid "کد درگاه تارا"
msgstr "Tara Gateway Code"

msgid "پرداخت با موفقیت انجام شد"
msgstr "Payment completed successfully"

msgid "پرداخت شما با شناسه پرداخت {track_id} به صورت موفق انجام شد."
msgstr "Your payment was successful with transaction ID {track_id}."

msgid ""
"پرداخت شما با شناسه پرداخت {track_id} ناموفق بود٬ لطفا مجددا تلاش نمایید و "
"یا در صورتی که اشتباه شده است٬ با مدیریت سایت تماس بگیرید."
msgstr ""
"Your payment with transaction ID {track_id} was unsuccessful. Please try "
"again, or contact the site administrator if this was a mistake."

msgid "تراکنش از سمت کاربر لغو شد"
msgstr "The transaction was canceled by the user"

msgid "خطا در ورود مجدد به درگاه. لطفاً دوباره تلاش کنید."
msgstr "Error re-entering the gateway. Please try again."

msgid "خطا در دریافت توکن پرداخت."
msgstr "Error receiving payment token."

msgid "خطا در احراز هویت درگاه تارا."
msgstr "Authentication error with the Tara gateway."

msgid ""
"شماره موبایل نا معتبر است، لطفا بررسی کنید. مثال شماره موبایل قابل قبول: "
"09121234567"
msgstr ""
"The mobile number is invalid. Please check. Example of valid number: "
"09121234567"

msgid "وارد کردن شماره موبایل جهت پرداخت با اپلیکیشن تارا الزامی است."
msgstr "Entering a mobile number is required to pay with the Tara app."
