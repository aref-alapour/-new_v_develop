{
  "scripts": {
    "build:front:css": "npx tailwindcss -i ./assets/css/input.css -o ./dist/front.css --minify",
    "build:front:js": "vite build -c vite.front.config.js",
    "build:js": "npm run build:front:js",
    "build": "npm run build:front:css && npm run build:js",
    "dev:front:css": "npx tailwindcss -i ./assets/css/input.css -o ./dist/front.css --watch --minify",
    "dev:js": "vite build -c vite.front.config.js --watch",
    "dev": "concurrently \"npm run dev:front:css\" \"npm run dev:js\"",
    "dev:tailwind-legacy": "npx tailwindcss -i ./assets/css/input.css -o ./assets/css/main.css --minify",
    "build:booking": "vite build -c vite.product-booking.config.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tailwind-scrollbar-hide": "^2.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animation-delay": "^2.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "alpinejs": "^3.15.12",
    "htmx.org": "^2.0.8"
  }
}
