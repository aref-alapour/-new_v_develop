{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["external", "wordpress", "gateway"],
  "properties": {
    "external": {
      "type": "object",
      "required": ["host", "database", "username", "password"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "password": { "type": "string" }
      },
      "additionalProperties": false
    },
    "wordpress": {
      "type": "object",
      "required": ["host", "database", "username", "password", "table_prefix"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "password": { "type": "string" },
        "table_prefix": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gateway": {
      "type": "object",
      "required": ["ajax_shared_secret"],
      "properties": {
        "ajax_shared_secret": { "type": "string", "minLength": 16 },
        "booking_use_internal": { "type": "boolean" },
        "booking_native_sanses": { "type": "boolean" },
        "rate_limits": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "per_ip": { "type": "integer", "minimum": 1 },
              "per_client": { "type": "integer", "minimum": 1 },
              "window_seconds": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
