{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "escapezoom/ez-product-card",
  "title": "EZ Product Card",
  "category": "escapezoom",
  "icon": "products",
  "description": "Product/room card (Stencil: ez-product-card). Rendered via theme (ez_render_product_card).",
  "attributes": {
    "productId": { "type": "number", "default": 0 },
    "productJson": { "type": "string", "default": "" },
    "status": { "type": "string", "default": "" },
    "href": { "type": "string", "default": "" },
    "isSlide": { "type": "boolean", "default": false }
  },
  "supports": { "html": false },
  "textdomain": "escapezoom-core"
}
