{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "escapezoom/ez-text-input",
  "title": "EZ Text Input",
  "category": "escapezoom",
  "icon": "edit",
  "description": "Text input (Stencil: ez-text-input).",
  "attributes": {
    "label": { "type": "string", "default": "" },
    "placeholder": { "type": "string", "default": "" },
    "name": { "type": "string", "default": "" },
    "value": { "type": "string", "default": "" },
    "type": { "type": "string", "default": "text" }
  },
  "supports": { "html": false },
  "textdomain": "escapezoom-core"
}
