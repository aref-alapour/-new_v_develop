function my_approve_comment_callback($new_status, $old_status, $comment) { // if a unapproved comment was approved

    if($old_status != $new_status) {

        $comment_id = $comment->comment_ID;
        $product_id = $comment->comment_post_ID;

        $power_map = [
            1 => 1,
            2 => 2,
            3 => 7,
