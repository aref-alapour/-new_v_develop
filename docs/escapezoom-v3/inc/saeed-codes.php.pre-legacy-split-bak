                    case "seconds":
                        val = 59 - parseInt(d.getSeconds())
                        break;
                    case "milliseconds":
                        val = 999 - parseInt(d.getMilliseconds())
                        break;
                    default:
                        break;
                }
                return val.toString().padStart(2, '0');
            }
