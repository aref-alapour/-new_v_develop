            $clone_product_rates[1098] -= (int)$comment_rating[1098] * $user_power;
            $clone_product_rates[1097] -= (int)$comment_rating[1097] * $user_power;
            $clone_product_rates[1096] -= (int)$comment_rating[1096] * $user_power;
            $clone_product_rates[1095] -= (int)$comment_rating[1095] * $user_power;
            $clone_product_rates[1094] -= (int)$comment_rating[1094] * $user_power;

            update_post_meta($product_id, 'clone_product_rates', $clone_product_rates);

            $temp2  = get_post_meta($product_id, 'comments_count_new', true);
            $temp2  = !empty($temp2) ? $temp2 : 0;
            update_post_meta($product_id, 'comments_count_new', --$temp2);

            $temp3  = get_post_meta($product_id, 'clone_comments_count_new', true);
            $temp3  = !empty($temp3) ? $temp3 : 0;
            update_post_meta($product_id, 'clone_comments_count_new', $temp3 - $user_power);
        }
    }
}
