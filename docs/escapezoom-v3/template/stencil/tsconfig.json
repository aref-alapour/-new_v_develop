{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "experimentalDecorators": true,
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "target": "es2022",
    "lib": ["dom", "es2022"]
  },
  "include": ["components"]
}
