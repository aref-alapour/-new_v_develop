# EZ Core encrypted secrets (do not commit secrets.enc or secrets.plain.json).
# PHP loads EZ_CORE_SECRETS_KEY from this file when the container env is not set (dev).
# Database credentials and ajax_shared_secret live inside secrets.enc (external + wordpress + gateway).
#
# Generate key (32 bytes, base64):
#   php -r "echo base64_encode(sodium_crypto_secretbox_keygen());"
#
# Create secrets.enc:
#   cp wp-content/mu-plugins/ez_core/config/secrets.plain.example.json wp-content/mu-plugins/ez_core/config/secrets.plain.json
#   # edit secrets.plain.json (external DB + gateway.ajax_shared_secret)
#   export EZ_CORE_SECRETS_KEY="your-base64-key"
#   php wp-content/mu-plugins/ez_core/bin/secrets-encrypt.php
#
# Health check:
#   php wp-content/mu-plugins/ez_core/bin/booking-db-health.php
#
# Dev: ez_core reads this file automatically when EZ_CORE_SECRETS_KEY is not in PHP env.
# Production: prefer EZ_CORE_SECRETS_KEY or EZ_CORE_SECRETS_KEY_FILE in the container.

EZ_CORE_SECRETS_KEY=
