# Copy to your Docker/host env (do not commit real secrets).

# Signed POST /ajax gateway (32+ random bytes; e.g. openssl rand -hex 32)
EZ_AJAX_SHARED_SECRET=

# Use web-service dispatch in-process from WordPress (recommended: 1)
EZ_BOOKING_USE_INTERNAL=1

# External queries DB (products_data, wp_zb_booking_history) — same password as WORDPRESS_DB_PASSWORD in dev unless MySQL root has no password
WORDPRESS_DB_EXT_NAME=escapezo_queries
WORDPRESS_DB_EXT_HOST=mysql
WORDPRESS_DB_EXT_USER=root
# Use the same value as WORDPRESS_DB_PASSWORD unless MySQL root has no password
WORDPRESS_DB_EXT_PASSWORD=

# Booking (wp-config.php / wp-config-docker.php → DB_EXT_* and EZ_BOOKING_*)
EZ_BOOKING_USE_INTERNAL=1
EZ_BOOKING_NATIVE_SANSES=1
